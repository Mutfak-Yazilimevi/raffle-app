{
  "manifest_version": 3,
  "name": "Instagram Raffle Helper",
  "version": "1.3.4",
  "description": "Instagram yorumlarını çeker ve takip şartlarını doğrular.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://mutfak-yazilimevi.github.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["pageHook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["followVerify.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
