{
  "manifest_version": 3,
  "name": "Instagram Raffle Helper",
  "version": "1.1.0",
  "description": "Instagram postlarındaki yorumları çekerek Çekiliş Uygulamasına aktarır.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
